# PowerBeacon Agent Environment Configuration
# Copy this file to .env and customize as needed

# Backend server URL
# The agent will register with this backend and receive WOL commands from it
BACKEND_URL=http://localhost:8000

# Agent API port
# The port on which the agent will listen for WOL requests
AGENT_PORT=18080

# Agent bind address
# The backend dispatches to the registered agent IP and port, so the agent
# must listen on an address reachable from the backend host/container.
AGENT_BIND=0.0.0.0

# Optional: Explicit IP address to register with the backend.
# Use this on multi-homed hosts, VPN-connected machines, or Docker Desktop
# setups where the default interface selection is not the backend-reachable one.
# AGENT_ADVERTISE_IP=192.168.1.10

# Optional: Agent token (obtained from registration)
# Usually not needed as the agent receives this during registration
# AGENT_TOKEN=your-token-here
